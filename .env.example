# --- Front (Vite) ---
VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Optionnel : analytics Plausible (domaine)
VITE_PLAUSIBLE_DOMAIN=
# Optionnel : vidéo de fond du Hero (URL publique .mp4/.webm) + image poster
VITE_HERO_VIDEO_URL=
VITE_HERO_POSTER_URL=
# Optionnel : film HTML animé embarqué en iframe (prioritaire sur la vidéo)
# Déposez l'export complet dans public/hero-film/ puis : VITE_HERO_FILM_URL=/hero-film/index.html
VITE_HERO_FILM_URL=
# Optionnel : vidéo de présentation de la page Formation (embed YouTube/Vimeo ou .mp4)
VITE_FORMATION_VIDEO_URL=

# --- Secrets Edge Functions (Supabase : Settings > Edge Functions > Secrets) ---
# OPENROUTER_API_KEY=sk-or-...        # IA via OpenRouter (modeles configurables dans /admin)
# STRIPE_SECRET_KEY=sk_live_...       # Paiement Kit + upsell
# STRIPE_WEBHOOK_SECRET=whsec_...     # Signature webhook Stripe
# RESEND_API_KEY=re_...               # Envoi emails (sequences)
# EMAIL_FROM="Le Negociateur <contact@votredomaine.fr>"
# SITE_URL=https://votredomaine.fr    # URL publique du site (liens emails / Stripe)
# APIFY_API_KEY=...                   # Agent prospection : scraper Apollo.io via Apify
# APIFY_APOLLO_ACTOR=code_crafter~apollo-io-scraper  # Actor Apify par defaut (override possible par liste)

# --- Agregation salariale multi-sources (rapport d'ecart) ---
# calculer-salaire.com et moicombien.fr sont publics (aucune cle requise).
# France Travail "Marche du travail" (optionnel) : OAuth2 client_credentials.
# FT_CLIENT_ID=...
# FT_CLIENT_SECRET=...
# FT_SCOPE=...                        # ex. "api_<nom> <scope>" fourni a l'inscription francetravail.io
# FT_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
# FT_MARCHE_TRAVAIL_URL=...           # endpoint marche du travail, gabarit avec {rome} et {zone}
# SUPABASE_SERVICE_ROLE_KEY=...       # Service role (Edge Functions uniquement, jamais cote front)
